# Anthropic
ANTHROPIC_API_KEY=

# LinkedIn credentials (for Playwright-based job scraping)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Agent behavior
MAX_LEADS_PER_DAY=10
MIN_FIT_SCORE=7              # 1–10 scale; leads below this are discarded
OUTREACH_MODE=local          # Options: local (save drafts to files) | auto_send (via SMTP)
DAILY_DIGEST_EMAIL=f.ahmad.job@gmail.com

# Optional: SMTP for sending emails directly (only needed if OUTREACH_MODE=auto_send)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_APP_PASSWORD=           # Gmail app password, NOT your account password
